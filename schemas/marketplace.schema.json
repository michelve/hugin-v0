{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michelve/hugin-v0/schemas/marketplace.schema.json",
  "title": "Claude Code Marketplace",
  "description": "Schema for Claude Code marketplace.json — based on official documentation at code.claude.com/docs/en/plugin-marketplaces.",
  "type": "object",
  "required": ["name", "owner", "plugins"],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference."
    },
    "name": {
      "type": "string",
      "description": "Marketplace catalog name (kebab-case, no spaces)."
    },
    "description": {
      "type": "string",
      "description": "Human-readable description of the marketplace catalog."
    },
    "owner": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "version": { "type": "string" },
        "pluginRoot": { "type": "string", "description": "Base directory prepended to relative plugin source paths." }
      }
    },
    "plugins": {
      "type": "array",
      "items": { "$ref": "#/$defs/pluginEntry" }
    }
  },
  "$defs": {
    "pluginEntry": {
      "type": "object",
      "required": ["name", "source"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "description": "Plugin identifier (kebab-case recommended)."
        },
        "description": {
          "type": "string",
          "description": "What the plugin does — shown in marketplace listings."
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+",
          "description": "Semver version string. Used by LSP plugins; optional for others."
        },
        "author": {
          "type": "object",
          "required": ["name"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" }
          }
        },
        "source": {
          "description": "Plugin source location — relative path, github, url, git-subdir, or npm.",
          "oneOf": [
            {
              "type": "string",
              "description": "Relative path within the same marketplace repo (e.g. './plugins/my-plugin')."
            },
            { "$ref": "#/$defs/sourceGithub" },
            { "$ref": "#/$defs/sourceUrl" },
            { "$ref": "#/$defs/sourceGitSubdir" },
            { "$ref": "#/$defs/sourceNpm" }
          ]
        },
        "category": {
          "type": "string",
          "enum": [
            "database",
            "deployment",
            "design",
            "development",
            "learning",
            "location",
            "migration",
            "monitoring",
            "productivity",
            "security",
            "testing"
          ],
          "description": "Plugin category for marketplace filtering."
        },
        "strict": {
          "type": "boolean",
          "description": "Controls whether plugin.json is the authority for component definitions. Default: true."
        },
        "lspServers": {
          "type": "object",
          "description": "Language server definitions — used only by dedicated LSP wrapper plugins. Non-LSP plugins ship .lsp.json at repo root for auto-discovery instead.",
          "additionalProperties": { "$ref": "#/$defs/lspServer" }
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "URL to the plugin's homepage or documentation."
        },
        "repository": {
          "type": "string",
          "description": "Source code repository URL."
        },
        "license": {
          "type": "string",
          "description": "SPDX license identifier (e.g. MIT, Apache-2.0)."
        },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Tags for plugin discovery and categorization."
        },
        "tags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Freeform tags (e.g. 'community-managed')."
        }
      }
    },
    "sourceGithub": {
      "type": "object",
      "required": ["source", "repo"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "github" },
        "repo": {
          "type": "string",
          "description": "GitHub repository in owner/repo format."
        },
        "ref": {
          "type": "string",
          "description": "Git branch or tag (defaults to repository default branch)."
        },
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Pin to a specific commit SHA."
        }
      }
    },
    "sourceUrl": {
      "type": "object",
      "required": ["source", "url"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "url" },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "Full git repository URL (https:// or git@). The .git suffix is optional."
        },
        "ref": {
          "type": "string",
          "description": "Git branch or tag (defaults to repository default branch)."
        },
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Pin to a specific commit SHA."
        }
      }
    },
    "sourceGitSubdir": {
      "type": "object",
      "required": ["source", "url", "path"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "git-subdir" },
        "url": {
          "type": "string",
          "description": "Git repository URL or GitHub owner/repo shorthand."
        },
        "path": {
          "type": "string",
          "description": "Subdirectory within the repo containing the plugin."
        },
        "ref": {
          "type": "string",
          "description": "Git ref (branch or tag) to use."
        },
        "sha": {
          "type": "string",
          "pattern": "^[0-9a-f]{40}$",
          "description": "Pin to a specific commit SHA."
        }
      }
    },
    "sourceNpm": {
      "type": "object",
      "required": ["source", "package"],
      "additionalProperties": false,
      "properties": {
        "source": { "const": "npm" },
        "package": {
          "type": "string",
          "description": "Package name or scoped package (e.g. @org/plugin)."
        },
        "version": {
          "type": "string",
          "description": "Version or version range (e.g. 2.1.0, ^2.0.0, ~1.5.0)."
        },
        "registry": {
          "type": "string",
          "description": "Custom npm registry URL."
        }
      }
    },
    "lspServer": {
      "type": "object",
      "required": ["command", "extensionToLanguage"],
      "additionalProperties": false,
      "properties": {
        "command": {
          "type": "string",
          "description": "Language server binary name."
        },
        "args": {
          "type": "array",
          "items": { "type": "string" },
          "description": "CLI arguments passed to the language server."
        },
        "extensionToLanguage": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Maps file extensions (e.g. '.ts') to language identifiers (e.g. 'typescript')."
        },
        "startupTimeout": {
          "type": "integer",
          "minimum": 0,
          "description": "Milliseconds to wait for the server to start (default varies by runtime)."
        }
      }
    }
  }
}
