{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/michelve/hugin-v0/schemas/plugin.schema.json",
  "title": "Claude Code Plugin Manifest",
  "description": "Schema for .claude-plugin/plugin.json — inferred from anthropics/claude-plugins-official. Official plugins use minimal manifests; everything else is auto-discovered from repo structure (.mcp.json, .lsp.json, agents/, skills/, hooks/).",
  "type": "object",
  "required": ["name", "description"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Plugin identifier (should match the marketplace entry name)."
    },
    "description": {
      "type": "string",
      "description": "Human-readable plugin description."
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+",
      "description": "Semver version string."
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      },
      "description": "Plugin author metadata."
    }
  }
}
