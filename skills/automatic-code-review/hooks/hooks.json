{
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Write|Edit|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_SKILL_DIR}/hooks/tools/automatic-code-review-plugin.sh log"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "${CLAUDE_SKILL_DIR}/hooks/tools/automatic-code-review-plugin.sh review"
                    }
                ]
            }
        ]
    }
}
